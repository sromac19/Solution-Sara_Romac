# Kopirajte ovaj file u .env i po potrebi prilagodite vrijednosti.

APP_NAME=TicketHub
ENVIRONMENT=local
LOG_LEVEL=INFO

# SQLite (default, brzo za lokalni razvoj - ne treba nikakav vanjski servis):
DATABASE_URL=sqlite+aiosqlite:///./tickethub.db

# PostgreSQL (kad se pokreće kroz docker-compose):
# DATABASE_URL=postgresql+asyncpg://tickethub:tickethub@localhost:5432/tickethub

DUMMYJSON_BASE_URL=https://dummyjson.com
DUMMYJSON_TODOS_LIMIT=150

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

SYNC_INTERVAL_SECONDS=300
CACHE_TTL_SECONDS=30

# Redis (opcionalno) - ostavite prazno/zakomentirano za in-memory cache.
# Postavlja se automatski kad se pokreće kroz docker-compose.
# REDIS_URL=redis://localhost:6379/0
